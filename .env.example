# Copy to .env and fill in values

# NewsAPI — get a free key at https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg://stonk:stonk@localhost:5432/stonk

# Sentiment model
SENTIMENT_MODEL=ProsusAI/finbert

# Tickers in scope (comma-separated)
TICKERS=AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL,AMD,NFLX,JPM

# Polling cadence (minutes)
INGEST_INTERVAL_MINUTES=60
