# Copy to .env and fill in values

# NewsAPI — get a free key at https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg://stonk:stonk@localhost:5432/stonk

# Sentiment model
SENTIMENT_MODEL=ProsusAI/finbert

# Tickers in scope (comma-separated)
TICKERS=AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL,AMD,NFLX,LZ

# Polling cadence (minutes)
INGEST_INTERVAL_MINUTES=60

# Alpaca paper trading (optional). Get free keys at https://alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_TRADE_SIZE_USD=500
ALPACA_MAX_POSITIONS=8
